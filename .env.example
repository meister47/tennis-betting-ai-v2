# Конфигурация API ключей для теннисной системы ставок
# Копируйте этот файл как .env.local и заполните своими ключами

# The Odds API (обязательно)
# Получите ключ на https://the-odds-api.com/
THE_ODDS_API_KEY=your_api_key_here_1234567890abcdef

# Дополнительные API (опционально)
# GITHUB_TOKEN=ghp_your_github_token_here
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Настройки системы (опционально)
# NODE_ENV=development
# LOG_LEVEL=info
# CACHE_TTL_HOURS=24

# Важно: Этот файл НЕ должен попадать в Git
# Добавьте .env.local в .gitignore
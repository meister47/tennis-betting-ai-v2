#!/bin/bash
# Pre-commit hook для проверки безопасности
# Проверяет, что в коммите нет токенов

echo "🔍 Проверка безопасности перед коммитом..."

# Переменные для цветного вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Файлы для проверки
FILES_TO_CHECK=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|json|py|ts|yml|yaml)$')

if [ -z "$FILES_TO_CHECK" ]; then
    echo -e "${GREEN}✅ Нет файлов для проверки безопасности${NC}"
    exit 0
fi

echo "Проверяю файлы:"
echo "$FILES_TO_CHECK" | sed 's/^/  /'

# Проверка на токены
FOUND_TOKENS=0

for file in $FILES_TO_CHECK; do
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Проверяем на наличие известных токенов
    if grep -q -E "(ghp_[a-zA-Z0-9]{36}|5bade59990c62f13daecce0427ec665e|api[_-]?key['\"]?\s*:\s*['\"][^'\"]{10,})" "$file"; then
        echo -e "${RED}❌ ОБНАРУЖЕН ТОКЕН В: $file${NC}"
        echo -e "${YELLOW}   Проблемные строки:${NC}"
        grep -n -E "(ghp_[a-zA-Z0-9]{36}|5bade59990c62f13daecce0427ec665e|api[_-]?key['\"]?\s*:\s*['\"][^'\"]{10,})" "$file" | sed 's/^/     /'
        FOUND_TOKENS=1
    fi
    
    # Проверяем на наличие других потенциальных секретов
    if grep -q -E "(password|secret|token|key)['\"]?\s*:\s*['\"][^'\"]{8,}" "$file"; then
        echo -e "${YELLOW}⚠️  ПОТЕНЦИАЛЬНЫЙ СЕКРЕТ В: $file${NC}"
        echo -e "${YELLOW}   Проверьте эти строки:${NC}"
        grep -n -E "(password|secret|token|key)['\"]?\s*:\s*['\"][^'\"]{8,}" "$file" | sed 's/^/     /'
    fi
done

if [ $FOUND_TOKENS -eq 1 ]; then
    echo ""
    echo -e "${RED}🚫 КОММИТ ОТМЕНЕН: Обнаружены токены в коде${NC}"
    echo ""
    echo -e "${YELLOW}📋 КАК ИСПРАВИТЬ:${NC}"
    echo "1. Используйте переменные окружения вместо хардкода"
    echo "2. Удалите токены из файлов"
    echo "3. Добавьте файлы снова (git add)"
    echo "4. Запустите скрипт исправления:"
    echo "   node scripts/fix-security-tokens.js"
    echo ""
    echo -e "${YELLOW}📚 ДОКУМЕНТАЦИЯ:${NC}"
    echo "См. SETUP_SECURITY.md для правильной настройки"
    exit 1
fi

echo -e "${GREEN}✅ Безопасность проверена, токенов не обнаружено${NC}"
exit 0